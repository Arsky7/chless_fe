# ============================================
# API CONFIGURATION
# ============================================
VITE_API_URL=http://localhost:8000/api
VITE_API_TIMEOUT=30000
VITE_API_VERSION=v1

# ============================================
# APP CONFIGURATION
# ============================================
VITE_APP_NAME="CHLESS Fashion"
VITE_APP_DESCRIPTION="Urban Streetwear Brand"
VITE_APP_VERSION=1.0.0
VITE_APP_URL=http://localhost:5173

# ============================================
# AUTHENTICATION
# ============================================
VITE_TOKEN_KEY=chless_auth_token
VITE_REFRESH_TOKEN_KEY=chless_refresh_token
VITE_USER_KEY=chless_user

# ============================================
# PAYMENT GATEWAY (MIDTRANS)
# ============================================
VITE_MIDTRANS_CLIENT_KEY=SB-Mid-client-kOte7tnGxXiqQ7R8
VITE_MIDTRANS_IS_PRODUCTION=false

# ============================================
# PAYMENT GATEWAY (XENDIT)
# ============================================
VITE_XENDIT_API_KEY=your-xendit-api-key

# ============================================
# SHIPPING (RAJAONGKIR)
# ============================================
VITE_RAJAONGKIR_API_KEY=your-rajaongkir-api-key
VITE_RAJAONGKIR_MODE=starter

# ============================================
# GOOGLE MAPS (UNTUK TRACKING)
# ============================================
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================
# FIREBASE (UNTUK PUSH NOTIFICATION)
# ============================================
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your-firebase-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# ============================================
# SOCIAL MEDIA
# ============================================
VITE_INSTAGRAM_URL=https://instagram.com/chless
VITE_TIKTOK_URL=https://tiktok.com/@chless
VITE_SHOPEE_URL=https://shopee.co.id/chless
VITE_TOKOPEDIA_URL=https://tokopedia.com/chless

# ============================================
# CONTACT INFORMATION
# ============================================
VITE_CONTACT_PHONE=6281234567890
VITE_CONTACT_EMAIL=cs@chless.com
VITE_CONTACT_WHATSAPP=6281234567890

# ============================================
# COMPANY INFORMATION
# ============================================
VITE_COMPANY_NAME="PT CHLESS FASHION INDONESIA"
VITE_COMPANY_ADDRESS="Jl. Fashion No. 123, Jakarta Pusat"
VITE_COMPANY_CITY="Jakarta"
VITE_COMPANY_PROVINCE="DKI Jakarta"
VITE_COMPANY_POSTAL_CODE=12345
VITE_COMPANY_EMAIL=info@chless.com

# ============================================
# FEATURE FLAGS
# ============================================
VITE_ENABLE_PAYMENT_GATEWAY=true
VITE_ENABLE_SHIPPING_TRACKING=true
VITE_ENABLE_RETURN_REQUEST=true
VITE_ENABLE_STAFF_MANAGEMENT=true
VITE_ENABLE_MULTI_WAREHOUSE=true
VITE_ENABLE_REVIEW_SYSTEM=true
VITE_ENABLE_WISHLIST=true

# ============================================
# PAGINATION
# ============================================
VITE_DEFAULT_PAGE_SIZE=20
VITE_MAX_PAGE_SIZE=100

# ============================================
# CURRENCY
# ============================================
VITE_CURRENCY=IDR
VITE_CURRENCY_SYMBOL=Rp
VITE_CURRENCY_LOCALE=id-ID

# ============================================
# DATE FORMAT
# ============================================
VITE_DATE_FORMAT=dd MMM yyyy
VITE_DATETIME_FORMAT=dd MMM yyyy HH:mm
VITE_TIMEZONE=Asia/Jakarta

# ============================================
# UPLOAD LIMITS
# ============================================
VITE_MAX_FILE_SIZE=5120 # 5MB in KB
VITE_MAX_IMAGE_SIZE=2048 # 2MB
VITE_MAX_VIDEO_SIZE=10240 # 10MB
VITE_ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp
VITE_ALLOWED_VIDEO_TYPES=mp4,mov,avi

# ============================================
# CACHE & STORAGE
# ============================================
VITE_CACHE_TTL=3600 # 1 hour
VITE_LOCAL_STORAGE_PREFIX=chless_
VITE_SESSION_TIMEOUT=7200 # 2 hours in seconds

# ============================================
# DEBUG & LOGGING
# ============================================
VITE_APP_DEBUG=true
VITE_LOG_LEVEL=debug
VITE_ENABLE_LOGGER=true